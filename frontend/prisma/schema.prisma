generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Empresa {
  id                     String                  @id @default(uuid())
  nombre                 String
  url                    String                  @unique
  logo                   String?
  telefono               String?
  whatsapp               String?
  email                  String?
  direccion              String?
  rfc                    String?
  config                 Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  razonSocial            String?
  codigoPostal           String?
  regimenFiscal          String?
  usoCFDI                String?
  loginBg                String?
  moneda                 String                  @default("MXN")
  almacenes              Almacen[]
  categorias             Categoria[]
  clientes               Cliente[]
  componentes            Componente[]
  compras                Compra[]
  equipos                Equipo[]
  gastosOperativos       GastoOperativo[]
  InventarioEquipo       InventarioEquipo[]
  movimientosInventario  MovimientoInventario[]
  obras                  Obra[]
  PendienteEquipo        PendienteEquipo[]
  productos              Producto[]
  proveedores            Proveedor[]
  registrosDiarios       RegistroDiario[]
  registrosMantenimiento RegistroMantenimiento[]
  resumenesSemana        ResumenSemana[]
  salidas                Salida[]
  usuarios               Usuario[]
}

model Usuario {
  id               String                 @id @default(uuid())
  empresaId        String
  nombre           String
  email            String                 @unique
  password         String
  role             Role                   @default(OPERADOR)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  movimientos      MovimientoInventario[]
  registrosDiarios RegistroDiario[]
  salidas          Salida[]
  empresa          Empresa                @relation(fields: [empresaId], references: [id])
}

model Categoria {
  id          String     @id @default(uuid())
  empresaId   String
  nombre      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  descripcion String?
  empresa     Empresa    @relation(fields: [empresaId], references: [id])
  productos   Producto[]
}

model Proveedor {
  id                     String                  @id @default(uuid())
  empresaId              String
  nombre                 String
  contacto               String?
  telefono               String?
  email                  String?
  direccion              String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  rfc                    String?
  razonSocial            String?
  codigoPostal           String?
  regimenFiscal          String?
  usoCFDI                String?
  compras                Compra[]
  movimientos            MovimientoInventario[]
  empresa                Empresa                 @relation(fields: [empresaId], references: [id])
  registrosMantenimiento RegistroMantenimiento[]
}

model Cliente {
  id               String                 @id @default(uuid())
  empresaId        String
  nombre           String
  contacto         String?
  email            String?
  telefono         String?
  direccion        String?
  rfc              String?
  razonSocial      String?
  codigoPostal     String?
  regimenFiscal    String?
  usoCFDI          String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  empresa          Empresa                @relation(fields: [empresaId], references: [id])
  movimientos      MovimientoInventario[]
  obras            Obra[]
  registrosDiarios RegistroDiario[]
}

model Almacen {
  id          String                 @id @default(uuid())
  empresaId   String
  nombre      String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  empresa     Empresa                @relation(fields: [empresaId], references: [id])
  movimientos MovimientoInventario[]
}

model Producto {
  id               String                 @id @default(uuid())
  empresaId        String
  nombre           String
  sku              String
  categoriaId      String
  unidad           String                 @default("pza")
  stockMinimo      Int                    @default(0)
  activo           Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  imagen           String?
  moneda           Moneda                 @default(MXN)
  precioCompra     Decimal                @default(0)
  stockActual      Decimal                @default(0)
  partNumber       String?
  leadTimeDias     Int?
  nivelReorden     Decimal?               @default(0) @db.Decimal
  cantidadReorden  Decimal?               @default(0) @db.Decimal
  tipoCambioRef    Decimal?               @db.Decimal
  suspendido       Boolean?               @default(false)
  equipoId         String?
  notas            String?
  detallesCompra   DetalleCompra[]
  detallesSalida   DetalleSalida[]
  gastosOperativos GastoOperativo[]       @relation("GastosProducto")
  movimientos      MovimientoInventario[]
  categoria        Categoria              @relation(fields: [categoriaId], references: [id])
  empresa          Empresa                @relation(fields: [empresaId], references: [id])
  equipo           Equipo?                @relation("ProductosEquipo", fields: [equipoId], references: [id], onUpdate: NoAction)

  @@unique([empresaId, sku])
  @@index([equipoId])
  @@index([partNumber])
}

model Compra {
  id          String                 @id @default(uuid())
  empresaId   String
  proveedorId String
  fecha       DateTime               @default(now())
  total       Decimal                @default(0)
  status      StatusCompra           @default(PENDIENTE)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  referencia  String?
  moneda      Moneda                 @default(MXN)
  notas       String?
  tipoCambio  Decimal?
  obraId      String?
  empresa     Empresa                @relation(fields: [empresaId], references: [id])
  obra        Obra?                  @relation(fields: [obraId], references: [id])
  proveedor   Proveedor              @relation(fields: [proveedorId], references: [id])
  detalles    DetalleCompra[]
  movimientos MovimientoInventario[]
}

model DetalleCompra {
  id             String   @id @default(uuid())
  compraId       String
  productoId     String
  cantidad       Decimal
  precioUnitario Decimal
  moneda         Moneda   @default(MXN)
  compra         Compra   @relation(fields: [compraId], references: [id])
  producto       Producto @relation(fields: [productoId], references: [id])
}

model Salida {
  id            String          @id @default(uuid())
  empresaId     String
  tipo          TipoSalida
  fecha         DateTime        @default(now())
  referencia    String?
  usuarioId     String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  clienteNombre String?
  notas         String?
  equipoId      String?
  obraId        String?
  detalles      DetalleSalida[]
  empresa       Empresa         @relation(fields: [empresaId], references: [id])
  equipo        Equipo?         @relation(fields: [equipoId], references: [id])
  obra          Obra?           @relation(fields: [obraId], references: [id])
  usuario       Usuario         @relation(fields: [usuarioId], references: [id])
}

model DetalleSalida {
  id             String   @id @default(uuid())
  salidaId       String
  productoId     String
  cantidad       Decimal
  precioUnitario Decimal
  moneda         Moneda   @default(MXN)
  producto       Producto @relation(fields: [productoId], references: [id])
  salida         Salida   @relation(fields: [salidaId], references: [id])
}

model MovimientoInventario {
  id               String          @id @default(uuid())
  empresaId        String
  productoId       String
  almacenId        String
  tipoMovimiento   TipoMovimiento
  cantidad         Decimal
  costoUnitario    Decimal
  fecha            DateTime        @default(now())
  referencia       String?
  usuarioId        String
  createdAt        DateTime        @default(now())
  precioVenta      Decimal?
  proveedorId      String?
  clienteNombre    String?
  clienteId        String?
  compraId         String?
  moneda           Moneda          @default(MXN)
  notas            String?
  registroDiarioId String?
  tipoCambio       Decimal?
  obraId           String?
  almacen          Almacen         @relation(fields: [almacenId], references: [id])
  cliente          Cliente?        @relation(fields: [clienteId], references: [id])
  compra           Compra?         @relation(fields: [compraId], references: [id])
  empresa          Empresa         @relation(fields: [empresaId], references: [id])
  obra             Obra?           @relation(fields: [obraId], references: [id])
  producto         Producto        @relation(fields: [productoId], references: [id])
  proveedor        Proveedor?      @relation(fields: [proveedorId], references: [id])
  registroDiario   RegistroDiario? @relation(fields: [registroDiarioId], references: [id])
  usuario          Usuario         @relation(fields: [usuarioId], references: [id])

  @@index([empresaId])
  @@index([productoId])
  @@index([almacenId])
  @@index([clienteId])
  @@index([compraId])
  @@index([registroDiarioId])
  @@index([obraId])
}

model Equipo {
  id                     String                  @id @default(uuid())
  empresaId              String
  nombre                 String
  modelo                 String?
  numeroSerie            String?
  numeroEconomico        String?
  hodometroInicial       Decimal                 @default(0)
  activo                 Boolean                 @default(true)
  notas                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  marca                  String?
  anoFabricacion         Int?
  fechaCompra            DateTime?               @db.Date
  facturaCompra          String?
  statusEquipo           StatusEquipo?           @default(ACTIVO)
  apodo                  String?
  acopladoCon            String?
  proveedorOrigen        String?
  seriePistolaActual     String?
  engineNumero           String?
  engineModelo           String?
  cpl                    String?
  family                 String?
  customerSpec           String?
  capacidadTanqueLts     Decimal?                @db.Decimal
  componentesInstalados  Componente[]            @relation("ComponenteEnEquipo")
  empresa                Empresa                 @relation(fields: [empresaId], references: [id])
  gastosOperativos       GastoOperativo[]
  InventarioEquipo       InventarioEquipo[]
  movimientosComponente  MovimientoComponente[]  @relation("MovimientosComponenteEquipo")
  obraEquipos            ObraEquipo[]
  PendienteEquipo        PendienteEquipo[]
  plantillaEquipos       PlantillaEquipo[]
  productos              Producto[]              @relation("ProductosEquipo")
  registrosDiarios       RegistroDiario[]
  registrosMantenimiento RegistroMantenimiento[]
  resumenesSemana        ResumenSemana[]
  salidas                Salida[]
}

model Obra {
  id                     String                  @id @default(uuid())
  empresaId              String
  nombre                 String
  clienteId              String?
  clienteNombre          String?
  ubicacion              String?
  bordo                  Decimal?
  espesor                Decimal?
  metrosContratados      Decimal?
  precioUnitario         Decimal?
  moneda                 Moneda                  @default(MXN)
  tipoCambio             Decimal?
  fechaInicio            DateTime?               @db.Date
  fechaFin               DateTime?               @db.Date
  status                 StatusObra              @default(ACTIVA)
  notas                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  profundidadCollar      Decimal?                @db.Decimal
  espaciamiento          Decimal?
  compras                Compra[]
  cortesFacturacion      CorteFacturacion[]
  gastosOperativos       GastoOperativo[]
  movimientosInventario  MovimientoInventario[]
  cliente                Cliente?                @relation(fields: [clienteId], references: [id])
  empresa                Empresa                 @relation(fields: [empresaId], references: [id])
  obraEquipos            ObraEquipo[]
  plantillas             PlantillaObra[]
  registrosDiarios       RegistroDiario[]
  registrosMantenimiento RegistroMantenimiento[]
  salidas                Salida[]

  @@index([empresaId])
  @@index([status])
}

model PlantillaObra {
  id                String                       @id @default(uuid())
  obraId            String
  numero            Int
  metrosContratados Decimal
  barrenos          Int                          @default(0)
  bordo             Decimal?
  espaciamiento     Decimal?
  precioUnitario    Decimal?
  moneda            Moneda                       @default(MXN)
  fechaInicio       DateTime?                    @db.Date
  fechaFin          DateTime?                    @db.Date
  notas             String?
  createdAt         DateTime                     @default(now())
  status            StatusPlantilla              @default(ACTIVA)
  gastosOperativos  GastoOperativo[]
  distribuciones    GastoOperativoDistribucion[]
  plantillaEquipos  PlantillaEquipo[]
  obra              Obra                         @relation(fields: [obraId], references: [id])
  registrosDiarios  RegistroDiario[]

  @@unique([obraId, numero])
  @@index([obraId])
}

model PlantillaEquipo {
  id          String        @id @default(uuid())
  plantillaId String
  equipoId    String
  fechaInicio DateTime      @db.Date
  fechaFin    DateTime?     @db.Date
  notas       String?
  createdAt   DateTime      @default(now())
  equipo      Equipo        @relation(fields: [equipoId], references: [id])
  plantilla   PlantillaObra @relation(fields: [plantillaId], references: [id])

  @@unique([plantillaId, equipoId])
  @@index([plantillaId])
  @@index([equipoId])
}

model ObraEquipo {
  id               String    @id @default(uuid())
  obraId           String
  equipoId         String
  fechaInicio      DateTime  @db.Date
  fechaFin         DateTime? @db.Date
  notas            String?
  createdAt        DateTime  @default(now())
  horometroFinal   Decimal?
  horometroInicial Decimal?
  fechaEntrada     DateTime? @db.Date
  fechaSalida      DateTime? @db.Date
  equipo           Equipo    @relation(fields: [equipoId], references: [id])
  obra             Obra      @relation(fields: [obraId], references: [id])

  @@index([obraId])
  @@index([equipoId])
}

model CorteFacturacion {
  id                String           @id @default(uuid())
  obraId            String
  numero            Int
  fechaInicio       DateTime         @db.Date
  fechaFin          DateTime         @db.Date
  barrenos          Int              @default(0)
  metrosLineales    Decimal          @default(0)
  bordo             Decimal?
  espesor           Decimal?
  volumenBruto      Decimal?
  porcentajePerdida Decimal?         @default(0)
  volumenNeto       Decimal?
  precioUnitario    Decimal?
  moneda            Moneda           @default(MXN)
  tipoCambio        Decimal?
  montoFacturado    Decimal?
  status            StatusCorte      @default(BORRADOR)
  notas             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  perdidaM3         Decimal?         @default(0) @db.Decimal
  profundidadCollar Decimal?         @db.Decimal
  obra              Obra             @relation(fields: [obraId], references: [id])
  corteRegistros    CorteRegistro[]
  RegistroDiario    RegistroDiario[]

  @@unique([obraId, numero])
  @@index([obraId])
}

model CorteRegistro {
  id         String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  corteId    String
  registroId String           @unique(map: "CorteRegistro_registroId_unique")
  createdAt  DateTime         @default(now()) @db.Timestamptz(6)
  corte      CorteFacturacion @relation(fields: [corteId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  registro   RegistroDiario   @relation(fields: [registroId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([corteId])
  @@index([registroId])
}

model RegistroDiario {
  id                    String                 @id @default(uuid())
  empresaId             String
  equipoId              String
  fecha                 DateTime               @db.Date
  horometroInicio       Decimal
  horometroFin          Decimal
  horasTrabajadas       Decimal
  barrenos              Int                    @default(0)
  metrosLineales        Decimal                @default(0)
  litrosDiesel          Decimal                @default(0)
  precioDiesel          Decimal                @default(0)
  tanqueInicio          Decimal?
  litrosTanqueInicio    Decimal?
  tanqueFin             Decimal?
  litrosTanqueFin       Decimal?
  operadores            Int                    @default(1)
  peones                Int                    @default(0)
  clienteId             String?
  obraNombre            String?
  semanaNum             Int?
  anoNum                Int?
  notas                 String?
  usuarioId             String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  obraId                String?
  corteId               String?
  profundidadPromedio   Decimal?               @db.Decimal
  porcentajeAvance      Decimal?               @db.Decimal
  rentaEquipoDiaria     Decimal?               @db.Decimal
  bordo                 Decimal?               @db.Decimal
  espaciamiento         Decimal?               @db.Decimal
  volumenRoca           Decimal?               @db.Decimal
  porcentajePerdida     Decimal?               @db.Decimal
  plantillaId           String?
  corteRegistro         CorteRegistro?
  movimientosInventario MovimientoInventario[]
  cliente               Cliente?               @relation(fields: [clienteId], references: [id])
  CorteFacturacion      CorteFacturacion?      @relation(fields: [corteId], references: [id], onUpdate: NoAction)
  empresa               Empresa                @relation(fields: [empresaId], references: [id])
  equipo                Equipo                 @relation(fields: [equipoId], references: [id])
  obra                  Obra?                  @relation(fields: [obraId], references: [id])
  plantilla             PlantillaObra?         @relation(fields: [plantillaId], references: [id], onUpdate: NoAction)
  usuario               Usuario                @relation(fields: [usuarioId], references: [id])

  @@unique([equipoId, fecha, plantillaId])
  @@index([empresaId])
  @@index([equipoId])
  @@index([fecha])
  @@index([obraId])
  @@index([corteId])
  @@index([plantillaId])
}

model ResumenSemana {
  id              String   @id @default(uuid())
  empresaId       String
  equipoId        String
  semanaNum       Int
  anoNum          Int
  fechaInicio     DateTime @db.Date
  fechaFin        DateTime @db.Date
  horasTotales    Decimal  @default(0)
  barrenos        Int      @default(0)
  metrosLineales  Decimal  @default(0)
  litrosPorHora   Decimal?
  litrosPorMetro  Decimal?
  metrosPorHora   Decimal?
  metrosPorDia    Decimal?
  costoDiesel     Decimal  @default(0)
  costoOperadores Decimal  @default(0)
  costoPeones     Decimal  @default(0)
  costoGastos     Decimal  @default(0)
  rentaEquipo     Decimal  @default(0)
  costoTotal      Decimal  @default(0)
  tipoCambio      Decimal?
  notas           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  empresa         Empresa  @relation(fields: [empresaId], references: [id])
  equipo          Equipo   @relation(fields: [equipoId], references: [id])

  @@unique([equipoId, semanaNum, anoNum])
  @@index([empresaId])
  @@index([equipoId])
}

model RegistroMantenimiento {
  id            String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  empresaId     String
  equipoId      String
  fecha         DateTime           @db.Date
  horometro     Decimal?           @db.Decimal
  tipo          TipoMantenimiento? @default(CORRECTIVO)
  descripcion   String
  observaciones String?
  costo         Decimal?           @default(0) @db.Decimal
  moneda        Moneda?            @default(MXN)
  tipoCambio    Decimal?           @db.Decimal
  proveedorId   String?
  obraId        String?
  createdAt     DateTime           @default(now()) @db.Timestamp(6)
  updatedAt     DateTime           @default(now()) @updatedAt @db.Timestamp(6)
  hrsUso        Decimal?           @db.Decimal
  numeroParte   String?
  empresa       Empresa            @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  equipo        Equipo             @relation(fields: [equipoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  obra          Obra?              @relation(fields: [obraId], references: [id], onUpdate: NoAction)
  proveedor     Proveedor?         @relation(fields: [proveedorId], references: [id], onUpdate: NoAction)

  @@index([empresaId])
  @@index([equipoId])
  @@index([fecha])
}

model GastoOperativo {
  id             String                       @id @default(dbgenerated("(gen_random_uuid())::text"))
  empresaId      String
  equipoId       String?
  semanaNum      Int
  anoNum         Int
  fechaInicio    DateTime?                    @db.Date
  categoria      CategoriaGasto?              @default(OTRO)
  producto       String
  unidad         String                       @default("pza")
  cantidad       Decimal                      @default(0) @db.Decimal
  precioUnitario Decimal                      @default(0) @db.Decimal
  total          Decimal?                     @default(dbgenerated("(cantidad * \"precioUnitario\")")) @db.Decimal
  moneda         Moneda?                      @default(MXN)
  tipoCambio     Decimal?                     @db.Decimal
  obraId         String?
  notas          String?
  createdAt      DateTime                     @default(now()) @db.Timestamp(6)
  updatedAt      DateTime                     @default(now()) @updatedAt @db.Timestamp(6)
  tipoGasto      TipoGasto                    @default(EXTERNO)
  productoId     String?
  plantillaId    String?
  nivelGasto     NivelGasto                   @default(GENERAL)
  origen         OrigenGasto                  @default(GENERAL_MANUAL)
  distribuible   Boolean                      @default(false)
  fechaFin       DateTime?                    @db.Date
  empresa        Empresa                      @relation(fields: [empresaId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  equipo         Equipo?                      @relation(fields: [equipoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  obra           Obra?                        @relation(fields: [obraId], references: [id], onUpdate: NoAction)
  plantilla      PlantillaObra?               @relation(fields: [plantillaId], references: [id], onUpdate: NoAction)
  productoRef    Producto?                    @relation("GastosProducto", fields: [productoId], references: [id], onUpdate: NoAction)
  distribuciones GastoOperativoDistribucion[]

  @@index([empresaId])
  @@index([equipoId, semanaNum, anoNum])
  @@index([obraId])
  @@index([productoId])
  @@index([plantillaId])
  @@index([nivelGasto])
  @@index([distribuible])
  @@index([equipoId])
}

model GastoOperativoDistribucion {
  id               String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  gastoOperativoId String
  plantillaId      String
  porcentaje       Decimal          @db.Decimal
  montoAsignado    Decimal          @db.Decimal
  metodoAsignacion MetodoAsignacion @default(MANUAL)
  notas            String?
  createdAt        DateTime         @default(now()) @db.Timestamp(6)
  gastoOperativo   GastoOperativo   @relation(fields: [gastoOperativoId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  plantilla        PlantillaObra    @relation(fields: [plantillaId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([gastoOperativoId])
  @@index([plantillaId])
}

model Componente {
  id             String                 @id @default(uuid())
  empresaId      String
  nombre         String
  serie          String?
  tipo           String?
  notas          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  equipoActualId String?
  empresa        Empresa                @relation(fields: [empresaId], references: [id])
  equipoActual   Equipo?                @relation("ComponenteEnEquipo", fields: [equipoActualId], references: [id])
  historial      MovimientoComponente[]

  @@index([empresaId])
  @@index([equipoActualId])
}

model MovimientoComponente {
  id           String     @id @default(uuid())
  componenteId String
  equipoId     String?
  fecha        DateTime   @db.Date
  tipo         String
  notas        String
  createdAt    DateTime   @default(now())
  componente   Componente @relation(fields: [componenteId], references: [id])
  equipo       Equipo?    @relation("MovimientosComponenteEquipo", fields: [equipoId], references: [id])

  @@index([componenteId])
  @@index([equipoId])
  @@index([fecha])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model InventarioEquipo {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  empresaId   String
  equipoId    String
