generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  GERENTE
  OPERADOR
}

enum Moneda {
  MXN
  USD
}

enum StatusCompra {
  PENDIENTE
  COMPLETADA
  CANCELADA
}

enum TipoSalida {
  VENTA
  CONSUMO_INTERNO
  PERDIDA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

// ── NUEVOS ENUMS ──────────────────────────────
enum StatusObra {
  ACTIVA
  PAUSADA
  TERMINADA
}

enum StatusCorte {
  BORRADOR
  FACTURADO
  COBRADO
}

// ─────────────────────────────────────────────
//  EMPRESA
// ─────────────────────────────────────────────

model Empresa {
  id            String   @id @default(uuid())
  nombre        String
  url           String   @unique
  logo          String?
  telefono      String?
  whatsapp      String?
  email         String?
  direccion     String?
  rfc           String?
  razonSocial   String?
  codigoPostal  String?
  regimenFiscal String?
  usoCFDI       String?
  loginBg       String?
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  usuarios              Usuario[]
  categorias            Categoria[]
  proveedores           Proveedor[]
  clientes              Cliente[]
  productos             Producto[]
  almacenes             Almacen[]
  compras               Compra[]
  salidas               Salida[]
  movimientosInventario MovimientoInventario[]
  equipos               Equipo[]
  registrosDiarios      RegistroDiario[]
  resumenesSemana       ResumenSemana[]
  obras                 Obra[]
}

// ─────────────────────────────────────────────
//  USUARIOS
// ─────────────────────────────────────────────

model Usuario {
  id        String   @id @default(uuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  nombre    String
  email     String   @unique
  password  String
  role      Role     @default(OPERADOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movimientos      MovimientoInventario[]
  salidas          Salida[]
  registrosDiarios RegistroDiario[]
}

// ─────────────────────────────────────────────
//  CATÁLOGOS BASE
// ─────────────────────────────────────────────

model Categoria {
  id          String   @id @default(uuid())
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  nombre      String
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productos Producto[]
}

model Proveedor {
  id            String   @id @default(uuid())
  empresaId     String
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  nombre        String
  contacto      String?
  telefono      String?
  email         String?
  direccion     String?
  rfc           String?
  razonSocial   String?
  codigoPostal  String?
  regimenFiscal String?
  usoCFDI       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  compras     Compra[]
  movimientos MovimientoInventario[]
}

model Cliente {
  id            String   @id @default(uuid())
  empresaId     String
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  nombre        String
  contacto      String?
  email         String?
  telefono      String?
  direccion     String?
  rfc           String?
  razonSocial   String?
  codigoPostal  String?
  regimenFiscal String?
  usoCFDI       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movimientos      MovimientoInventario[]
  registrosDiarios RegistroDiario[]
  obras            Obra[]
}

model Almacen {
  id        String   @id @default(uuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  nombre    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movimientos MovimientoInventario[]
}

// ─────────────────────────────────────────────
//  PRODUCTOS / INSUMOS
// ─────────────────────────────────────────────

model Producto {
  id           String    @id @default(uuid())
  empresaId    String
  empresa      Empresa   @relation(fields: [empresaId], references: [id])
  nombre       String
  sku          String
  categoriaId  String
  categoria    Categoria @relation(fields: [categoriaId], references: [id])
  unidad       String    @default("pza")
  precioCompra Decimal   @default(0)
  moneda       Moneda    @default(MXN)
  stockActual  Decimal   @default(0)
  stockMinimo  Int       @default(0)
  imagen       String?
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  detallesCompra DetalleCompra[]
  detallesSalida DetalleSalida[]
  movimientos    MovimientoInventario[]

  @@unique([empresaId, sku])
}

// ─────────────────────────────────────────────
//  COMPRAS (ENTRADAS)
// ─────────────────────────────────────────────

model Compra {
  id          String       @id @default(uuid())
  empresaId   String
  empresa     Empresa      @relation(fields: [empresaId], references: [id])
  proveedorId String
  proveedor   Proveedor    @relation(fields: [proveedorId], references: [id])
  referencia  String?
  fecha       DateTime     @default(now())
  total       Decimal      @default(0)
  moneda      Moneda       @default(MXN)
  tipoCambio  Decimal?
  status      StatusCompra @default(PENDIENTE)
  notas       String?
  // Obra a la que se destinan los insumos (opcional)
  obraId      String?
  obra        Obra?        @relation(fields: [obraId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  detalles    DetalleCompra[]
  movimientos MovimientoInventario[]
}

model DetalleCompra {
  id             String   @id @default(uuid())
  compraId       String
  compra         Compra   @relation(fields: [compraId], references: [id])
  productoId     String
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Decimal
  precioUnitario Decimal
  moneda         Moneda   @default(MXN)
}

// ─────────────────────────────────────────────
//  SALIDAS / CONSUMOS INTERNOS
// ─────────────────────────────────────────────

model Salida {
  id            String     @id @default(uuid())
  empresaId     String
  empresa       Empresa    @relation(fields: [empresaId], references: [id])
  tipo          TipoSalida
  fecha         DateTime   @default(now())
  referencia    String?
  clienteNombre String?
  notas         String?
  // Vinculación a obra y equipo
  obraId        String?
  obra          Obra?      @relation(fields: [obraId], references: [id])
  equipoId      String?
  equipo        Equipo?    @relation(fields: [equipoId], references: [id])
  usuarioId     String
  usuario       Usuario    @relation(fields: [usuarioId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  detalles DetalleSalida[]
}

model DetalleSalida {
  id             String   @id @default(uuid())
  salidaId       String
  salida         Salida   @relation(fields: [salidaId], references: [id])
  productoId     String
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Decimal
  precioUnitario Decimal
  moneda         Moneda   @default(MXN)
}

// ─────────────────────────────────────────────
//  MOVIMIENTOS DE INVENTARIO (KARDEX)
// ─────────────────────────────────────────────

model MovimientoInventario {
  id             String         @id @default(uuid())
  empresaId      String
  empresa        Empresa        @relation(fields: [empresaId], references: [id])
  productoId     String
  producto       Producto       @relation(fields: [productoId], references: [id])
  almacenId      String
  almacen        Almacen        @relation(fields: [almacenId], references: [id])
  tipoMovimiento TipoMovimiento
  cantidad       Decimal
  costoUnitario  Decimal
  moneda         Moneda         @default(MXN)
  tipoCambio     Decimal?
  precioVenta    Decimal?
  proveedorId    String?
  proveedor      Proveedor?     @relation(fields: [proveedorId], references: [id])
  clienteId      String?
  cliente        Cliente?       @relation(fields: [clienteId], references: [id])
  clienteNombre  String?
  compraId       String?
  compra         Compra?        @relation(fields: [compraId], references: [id])
  registroDiarioId String?
  registroDiario   RegistroDiario? @relation(fields: [registroDiarioId], references: [id])
  // Trazabilidad por obra
  obraId         String?
  obra           Obra?          @relation(fields: [obraId], references: [id])
  fecha          DateTime       @default(now())
  referencia     String?
  notas          String?
  usuarioId      String
  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  createdAt      DateTime       @default(now())

  @@index([empresaId])
  @@index([productoId])
  @@index([almacenId])
  @@index([clienteId])
  @@index([compraId])
  @@index([registroDiarioId])
  @@index([obraId])
}

// ─────────────────────────────────────────────
//  EQUIPOS (MAQUINARIA)
// ─────────────────────────────────────────────

model Equipo {
  id               String   @id @default(uuid())
  empresaId        String
  empresa          Empresa  @relation(fields: [empresaId], references: [id])
  nombre           String
  modelo           String?
  numeroSerie      String?
  numeroEconomico  String?
  hodometroInicial Decimal  @default(0)
  activo           Boolean  @default(true)
  notas            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  registrosDiarios RegistroDiario[]
  resumenesSemana  ResumenSemana[]
  obraEquipos      ObraEquipo[]
  salidas          Salida[]
}

// ─────────────────────────────────────────────
//  OBRAS / CONTRATOS
// ─────────────────────────────────────────────

model Obra {
  id                String     @id @default(uuid())
  empresaId         String
  empresa           Empresa    @relation(fields: [empresaId], references: [id])

  // Datos del contrato
  nombre            String                        // nombre de la obra
  clienteId         String?
  cliente           Cliente?   @relation(fields: [clienteId], references: [id])
  clienteNombre     String?                       // nombre libre si no está en catálogo
  ubicacion         String?

  // Dimensiones para cálculo de volumen (hoja Plantilla)
  bordo             Decimal?                      // ancho del bordo (m)
  espesor           Decimal?                      // espesor de la capa (m)
  profundidadCollar Decimal?                      // profundidad de collar por defecto (m) — usado en pérdida automática

  // Contrato
  metrosContratados Decimal?                      // metros lineales totales contratados
  precioUnitario    Decimal?                      // precio por m³ o mt lineal
  moneda            Moneda     @default(MXN)
  tipoCambio        Decimal?

  // Fechas
  fechaInicio       DateTime?  @db.Date
  fechaFin          DateTime?  @db.Date           // estimada o real al cerrar

  // Estado
  status            StatusObra @default(ACTIVA)
  notas             String?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relaciones
  obraEquipos           ObraEquipo[]
  registrosDiarios      RegistroDiario[]
  cortesFacturacion     CorteFacturacion[]
  movimientosInventario MovimientoInventario[]
  salidas               Salida[]
  compras               Compra[]

  @@index([empresaId])
  @@index([status])
}

// ─────────────────────────────────────────────
//  HISTORIAL EQUIPO ↔ OBRA
// ─────────────────────────────────────────────

model ObraEquipo {
  id          String    @id @default(uuid())
  obraId      String
  obra        Obra      @relation(fields: [obraId], references: [id])
  equipoId    String
  equipo      Equipo    @relation(fields: [equipoId], references: [id])
  fechaInicio DateTime  @db.Date
  fechaFin    DateTime? @db.Date                  // null = sigue activo en esta obra
  notas       String?
  createdAt   DateTime  @default(now())

  @@index([obraId])
  @@index([equipoId])
}

// ─────────────────────────────────────────────
//  CORTES DE FACTURACIÓN (hoja Plantilla)
// ─────────────────────────────────────────────

model CorteFacturacion {
  id          String      @id @default(uuid())
  obraId      String
  obra        Obra        @relation(fields: [obraId], references: [id])

  numero      Int                                 // corte 1, 2, 3...
  fechaInicio DateTime    @db.Date
  fechaFin    DateTime    @db.Date

  // Producción del período
  barrenos       Int      @default(0)
  metrosLineales Decimal  @default(0)

  // Cálculo de volumen (replica hoja Plantilla)
  bordo             Decimal?                      // puede diferir del de la obra si cambia
  espesor           Decimal?
  profundidadCollar Decimal?                      // override por corte; si null usa el de la obra
  volumenBruto      Decimal?                      // bordo × espesor × metrosLineales
  // perdidaM3 = barrenos × profundidadCollar × bordo × espesor (si profundidadCollar presente)
  // o ingresada manualmente si profundidadCollar es null
  perdidaM3         Decimal?  @default(0)         // pérdida absoluta en m³ (campo "% Perd." del Excel)
  porcentajePerdida Decimal?  @default(0)            // calculado: perdidaM3 / volumenBruto × 100
  volumenNeto    Decimal?                         // volumenBruto − perdidaM3

  // Facturación
  precioUnitario Decimal?
  moneda         Moneda   @default(MXN)
  tipoCambio     Decimal?
  montoFacturado Decimal?                         // volumenNeto × precioUnitario

  status         StatusCorte @default(BORRADOR)
  notas          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Registros diarios vinculados a este corte
  corteRegistros CorteRegistro[]

  @@unique([obraId, numero])
  @@index([obraId])
}

// ─────────────────────────────────────────────
//  VÍNCULO CORTE ↔ REGISTRO DIARIO
// ─────────────────────────────────────────────

model CorteRegistro {
  id         String           @id @default(uuid())
  corteId    String
  corte      CorteFacturacion @relation(fields: [corteId], references: [id], onDelete: Cascade)
  registroId String           @unique                // un registro → un solo corte
  registro   RegistroDiario   @relation(fields: [registroId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@index([corteId])
  @@index([registroId])
}

// ─────────────────────────────────────────────
//  REGISTRO DIARIO DE OPERACIÓN (hoja Rpte)
// ─────────────────────────────────────────────

model RegistroDiario {
  id        String   @id @default(uuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  equipoId  String
  equipo    Equipo   @relation(fields: [equipoId], references: [id])
  fecha     DateTime @db.Date

  // Obra a la que pertenece este día de operación
  obraId    String?
  obra      Obra?    @relation(fields: [obraId], references: [id])

  // Horómetro
  horometroInicio    Decimal
  horometroFin       Decimal
  horasTrabajadas    Decimal

  // Producción
  barrenos           Int     @default(0)
  metrosLineales     Decimal @default(0)

  // Diésel
  litrosDiesel       Decimal @default(0)
  precioDiesel       Decimal @default(0)

  // Nivel de tanque interno
  tanqueInicio       Decimal?
  litrosTanqueInicio Decimal?
  tanqueFin          Decimal?
  litrosTanqueFin    Decimal?

  // Personal
  operadores         Int     @default(1)
  peones             Int     @default(0)

  // Cliente / obra (texto libre — se mantiene por compatibilidad)
  clienteId          String?
  cliente            Cliente? @relation(fields: [clienteId], references: [id])
  obraNombre         String?

  // Agrupación semanal
  semanaNum          Int?
  anoNum             Int?

  notas              String?
  usuarioId          String
  usuario            Usuario  @relation(fields: [usuarioId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  movimientosInventario MovimientoInventario[]
  // Vínculo al corte de facturación (null = pendiente de facturar)
  corteRegistro         CorteRegistro?

  @@unique([equipoId, fecha])
  @@index([empresaId])
  @@index([equipoId])
  @@index([fecha])
  @@index([obraId])
}

// ─────────────────────────────────────────────
//  RESUMEN SEMANAL (hoja Semana)
// ─────────────────────────────────────────────

model ResumenSemana {
  id        String   @id @default(uuid())
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  equipoId  String
  equipo    Equipo   @relation(fields: [equipoId], references: [id])

  semanaNum        Int
  anoNum           Int
  fechaInicio      DateTime @db.Date
  fechaFin         DateTime @db.Date

  // Producción acumulada
  horasTotales     Decimal  @default(0)
  barrenos         Int      @default(0)
  metrosLineales   Decimal  @default(0)

  // KPIs
  litrosPorHora    Decimal?
  litrosPorMetro   Decimal?
  metrosPorHora    Decimal?
  metrosPorDia     Decimal?

  // Costos (MXN)
  costoDiesel      Decimal  @default(0)
  costoOperadores  Decimal  @default(0)
  costoPeones      Decimal  @default(0)
  costoGastos      Decimal  @default(0)
  rentaEquipo      Decimal  @default(0)
  costoTotal       Decimal  @default(0)

  tipoCambio       Decimal?
  notas            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([equipoId, semanaNum, anoNum])
  @@index([empresaId])
  @@index([equipoId])
}
